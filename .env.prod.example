# Producción — copiá este archivo como .env.prod EN EL SERVIDOR (/opt/spotwise).
# NO se commitea (contiene secretos). El frontend NO usa este archivo: su API key
# de Maps se inyecta en build-time vía el secret VITE_GOOGLE_MAPS_API_KEY.

# --- Django ---
DJANGO_SECRET_KEY=generá-uno-largo-y-aleatorio
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=tu-dominio.com,www.tu-dominio.com,IP-PUBLICA-O-DNS-DE-LA-EC2
DJANGO_CSRF_TRUSTED_ORIGINS=https://tu-dominio.com
# Poné en True cuando tengas HTTPS configurado:
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_COOKIE_SECURE=False

# --- Base de datos: RDS PostgreSQL/PostGIS ---
POSTGRES_DB=spotwise
POSTGRES_USER=spotwise
POSTGRES_PASSWORD=la-password-de-rds
POSTGRES_HOST=tu-instancia.xxxxxx.us-east-1.rds.amazonaws.com
POSTGRES_PORT=5432
# RDS exige conexión cifrada:
POSTGRES_SSLMODE=require

# --- CORS (mismo origen vía nginx; solo si servís el front en otro dominio) ---
CORS_ALLOWED_ORIGINS=https://tu-dominio.com

# --- Google Places (key de servidor, NUNCA en el frontend) ---
GOOGLE_PLACES_API_KEY=tu-key-server-de-places
